FROM node:22-bookworm-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
	PYTHONUNBUFFERED=1 \
	PIP_NO_CACHE_DIR=1 \
	PIP_DEFAULT_TIMEOUT=120 \
	PIP_RETRIES=10 \
	PATH="/opt/boss-agent-venv/bin:${PATH}"

WORKDIR /app

RUN apt-get update \
	&& apt-get install -y --no-install-recommends python3 python3-venv \
	&& rm -rf /var/lib/apt/lists/*

COPY requirements.docker.txt pyproject.toml README.md /tmp/boss-agent-build/
COPY src /tmp/boss-agent-build/src
COPY mcp-server /tmp/boss-agent-build/mcp-server

RUN python3 -m venv /opt/boss-agent-venv \
	&& pip install -r /tmp/boss-agent-build/requirements.docker.txt \
	&& pip install --no-deps /tmp/boss-agent-build

WORKDIR /app/demo/interview-simulator

EXPOSE 5173

CMD ["sh", "-c", "npm install && npm run dev -- --host 0.0.0.0 --port 5173"]
