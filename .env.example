# Optional repo-local environment overrides for docker-compose and local runs.
# Copy to `.env` only if you need to override defaults.

# Start the full local project stack.
# docker compose up -d
#
# BOSS frontend: http://127.0.0.1:3101
# Personal RAG frontend: http://127.0.0.1:3100
# Personal RAG API: http://127.0.0.1:18020

# BOSS frontend compose service.
# BOSS_FRONTEND_PORT=3101

# Boss RAG local database path inside the container.
# BOSS_RAG_DB_PATH=/root/.boss-agent/boss-rag.db

# BOSS_AGENT's profile-aware RAG endpoint.
# Docker Compose defaults this to the local personal RAG API on 18020.
# BOSS_PERSONAL_RAG_BASE_URL=http://127.0.0.1:18020
# BOSS_RAG_RAG_BASE_URL=http://127.0.0.1:18020

# RAG request timeout in seconds.
# BOSS_RAG_RAG_TIMEOUT_SECONDS=20

# Frontend bridge timeout for long-running boss-agent-cli commands. Set 0 to use built-in defaults.
# Boss auto-greet derives a longer timeout from the requested count, up to the 150-candidate cap.
# BOSS_RAG_COMMAND_TIMEOUT_SECONDS=0

# RAG API auth. Docker Compose defaults to bearer and reuses RAG_AUTH_API_KEY.
# Model endpoints below still do not need API keys.
# RAG_AUTH_API_KEY=
# RAG_AUTH_API_KEY_USER_ID=user_roster_13951
# BOSS_RAG_RAG_AUTH_MODE=bearer

# Local personal RAG compose stack.
# This keeps Boss personal/profile data separate from any company Enterprise RAG database.
# Runtime data stays under ./storage/personal-rag and does not use HOST_SHARED_DATA_DIR.
# This starts by default with docker compose up -d.
# BOSS_PERSONAL_RAG_API_PORT=18020
# BOSS_PERSONAL_RAG_FRONTEND_URL=http://127.0.0.1:3100
# BOSS_PERSONAL_RAG_QDRANT_COLLECTION=boss_personal_rag_v1
# BOSS_PERSONAL_RAG_POSTGRES_PORT=15433
# BOSS_PERSONAL_RAG_QDRANT_HTTP_PORT=16333
# BOSS_PERSONAL_RAG_REDIS_PORT=16380
#
# Local personal RAG API auth. Defaults to bearer and inherits RAG_AUTH_API_KEY.
# If you override the key, override the user id too.
# BOSS_PERSONAL_RAG_AUTH_MODE=bearer
# BOSS_PERSONAL_RAG_AUTH_API_KEY=
# BOSS_PERSONAL_RAG_AUTH_API_KEY_USER_ID=user_roster_13951
#
# Remote model topology for the personal RAG stack.
# Retrieval/index data stays local; only generation and embedding call 192.168.10.200.
# BOSS_PERSONAL_RAG_LLM_PROVIDER=openai
# BOSS_PERSONAL_RAG_LLM_BASE_URL=http://192.168.10.200:8000/v1
# BOSS_PERSONAL_RAG_LLM_API_KEY=
# BOSS_PERSONAL_RAG_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# BOSS_PERSONAL_RAG_EMBEDDING_PROVIDER=openai
# BOSS_PERSONAL_RAG_EMBEDDING_BASE_URL=http://192.168.10.200:8002/v1
# BOSS_PERSONAL_RAG_EMBEDDING_API_KEY=
# BOSS_PERSONAL_RAG_EMBEDDING_MODEL=BAAI/bge-m3
# BOSS_PERSONAL_RAG_RERANKER_PROVIDER=heuristic

# Explicitly allow reading Boss messages for RAG sync.
# BOSS_RAG_ALLOW_MESSAGE_READ=false

# Fixed local answer for salary questions. When set, salary prompts do not call RAG.
# BOSS_RAG_SALARY_REPLY=当前薪资按候选人预设回复；期望薪资按候选人预设回复。

# Explicit opt-in for batch greet automation.
# BOSS_BATCH_GREET_AUTO_ENABLED=false
